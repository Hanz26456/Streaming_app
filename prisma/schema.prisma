generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  avatarUrl    String?
  role         String         @default("USER")
  password     String
  isPremium    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  watchHistory WatchHistory[]
  watchlist    Watchlist[]
  reviews      Review[]
}

model Movie {
  id           Int            @id @default(autoincrement())
  tmdbId       Int?
  title        String
  description  String         @db.Text
  genre        String
  releaseYear  Int
  duration     Int
  videoUrl     String
  posterUrl    String
  backdropUrl  String?
  trailerKey   String?
  isPremium    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  watchHistory WatchHistory[]
  watchlist    Watchlist[]
  reviews      Review[]
}

model WatchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  movieId   Int?
  episodeId Int?
  seriesId  Int?
  progress  Float    @default(0)
  duration  Float    @default(0)
  watchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  movie     Movie?   @relation(fields: [movieId], references: [id])
  episode   Episode? @relation(fields: [episodeId], references: [id])
  series    Series?  @relation(fields: [seriesId], references: [id])

  @@unique([userId, movieId])
  @@unique([userId, episodeId])
}

model Series {
  id           Int            @id @default(autoincrement())
  tmdbId       Int?
  title        String
  description  String?        @db.Text
  genre        String?
  releaseYear  Int?
  posterUrl    String?
  backdropUrl  String?
  trailerKey   String?
  totalSeasons Int?           @default(1)
  episodes     Episode[]
  isPremium    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  watchlist    Watchlist[]
  watchHistory WatchHistory[]
  reviews      Review[]
}

model Episode {
  id            Int            @id @default(autoincrement())
  seriesId      Int
  series        Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  title         String
  description   String?        @db.Text
  season        Int            @default(1)
  episodeNumber Int
  duration      Int?
  videoUrl      String?
  thumbnailUrl  String?
  createdAt     DateTime       @default(now())
  watchHistory  WatchHistory[]

  @@unique([seriesId, season, episodeNumber])
}

model Watchlist {
  id       Int      @id @default(autoincrement())
  userId   Int
  movieId  Int?
  seriesId Int?
  addedAt  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  movie    Movie?   @relation(fields: [movieId], references: [id])
  series   Series?  @relation(fields: [seriesId], references: [id])

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  movieId   Int?
  seriesId  Int?
  liked     Boolean  // true = Like, false = Dislike
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  movie     Movie?   @relation(fields: [movieId], references: [id])
  series    Series?  @relation(fields: [seriesId], references: [id])

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
}